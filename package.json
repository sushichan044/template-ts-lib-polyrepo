{
  "name": "template-ts-lib-polyrepo",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/sushichan044/template-ts-lib-polyrepo#readme",
  "bugs": {
    "url": "https://github.com/sushichan044/template-ts-lib-polyrepo/issues"
  },
  "license": "",
  "author": {
    "name": "sushichan044",
    "url": "https://github.com/sushichan044"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushichan044/template-ts-lib-polyrepo.git"
  },
  "funding": "https://github.com/sponsors/sushichan044",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "lint": "oxlint --max-warnings 0 --fix",
    "lint:check": "oxlint --max-warnings 0",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest --run",
    "tidy": "pnpm run lint && pnpm run format && pnpm run test",
    "check": "pnpm run format:check && pnpm run lint:check && pnpm run test && pnpm run build",
    "build": "tsdown",
    "pkg-pr-new": "pkg-pr-new publish --compact --comment=update --pnpm"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:dev",
    "@types/node": "catalog:dev",
    "@typescript/native-preview": "catalog:dev",
    "@virtual-live-lab/tsconfig": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "pkg-pr-new": "catalog:dev",
    "publint": "catalog:dev",
    "release-it": "catalog:dev",
    "release-it-pnpm": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "unplugin-unused": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "packageManager": "pnpm@10.33.0"
}
